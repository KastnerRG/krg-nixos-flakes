[OPTIONS]

enable: 1

[RULES]

# krg-prod — lab-wide production stack (Traefik + Authentik + services).
# SSH restricted to UCSD + off-campus admin. HTTP/HTTPS public for Traefik
# (Let's Encrypt ACME challenges + service ingress).

IN SSH(ACCEPT)           -source +dc/ucsd -log nolog
IN SSH(ACCEPT)           -source +dc/ops  -log nolog
IN ACCEPT -p tcp -dport 80  -log nolog
IN ACCEPT -p tcp -dport 443 -log nolog

IN DROP -log nolog
