[OPTIONS]

enable: 1

[RULES]

# krg-vault — OpenBao secrets manager.
# SSH restricted to UCSD + off-campus admin.
# OpenBao API (8200) restricted to internal sealab subnet only.

IN SSH(ACCEPT)                       -source +dc/ucsd -log nolog
IN SSH(ACCEPT)                       -source +dc/ops  -log nolog
IN ACCEPT -p tcp -dport 8200         -source +dc/sealab -log nolog

IN DROP -log nolog
