# Managed by Ansible (krg-infra) — Proxmox host SSH hardening.
# Drop-in overrides /etc/ssh/sshd_config (which Includes sshd_config.d/*.conf).
#
# Root cause of the breach: password (dictionary) auth on root over SSH.
PasswordAuthentication no
KbdInteractiveAuthentication no
PermitRootLogin {{ proxmox_ssh_permit_root }}
PubkeyAuthentication yes
MaxAuthTries 3
LoginGraceTime 30
X11Forwarding no
{% if proxmox_ssh_restrict_algorithms %}
# ed25519-only. WARNING: can break PVE cluster inter-node SSH if those keys are RSA.
PubkeyAcceptedAlgorithms {{ proxmox_ssh_pubkey_algorithms }}
{% endif %}
