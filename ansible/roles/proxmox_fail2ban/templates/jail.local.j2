# Managed by Ansible (krg-infra).
[DEFAULT]
bantime  = {{ proxmox_fail2ban_bantime }}
findtime = {{ proxmox_fail2ban_findtime }}
maxretry = {{ proxmox_fail2ban_maxretry }}
backend  = systemd
ignoreip = {{ proxmox_fail2ban_ignoreip | join(' ') }}

[sshd]
enabled = true

# The PVE web UI (8006) is also brute-forceable. To ban those too, ship a
# filter at filter.d/proxmox.conf matching pvedaemon auth failures, then:
#   [proxmox]
#   enabled  = true
#   port     = 8006,https,http
#   filter   = proxmox
#   backend  = systemd
