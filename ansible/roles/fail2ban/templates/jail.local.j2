# Managed by Ansible (krg-infra fail2ban).
[DEFAULT]
bantime  = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}
backend  = systemd
ignoreip = {{ fail2ban_ignoreip | join(' ') }}

[sshd]
enabled = true

# The PVE web UI (8006) is also brute-forceable. To ban those too, ship a
# filter at filter.d/proxmox.conf matching pvedaemon auth failures, then add a
# [proxmox] jail (port 8006,https,http; backend systemd).
