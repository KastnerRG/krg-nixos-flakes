# OpenTofu / Terraform working files — never commit state (holds DSM secrets)
# or real tfvars.
.terraform/
# .terraform.lock.hcl is ignored until you decide to commit it (recommended once the
# provider set is stable); remove the line below to start tracking it.
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# DSM config exports / SQL dumps — secret + PII-bearing, never commit (review locally only)
*.dss
*.sql
*.db
*_ConfBkp*
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
