NODE_ENV=production

URL=https://wiki.fabricant.ucsd.edu
PORT=3000

COLLABORATION_URL=
CDN_URL=
WEB_CONCURRENCY=1

# Generate with: openssl rand -hex 32
SECRET_KEY=generate_a_new_key
UTILS_SECRET=generate_a_new_key

DEFAULT_LANGUAGE=en_US

# Database
DATABASE_CONNECTION_POOL_MIN=
DATABASE_CONNECTION_POOL_MAX=
PGSSLMODE=disable

# Redis
REDIS_URL=redis://outline_redis:6379
REDIS_COLLABORATION_URL=

# File storage
FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FILE_STORAGE_UPLOAD_MAX_SIZE=262144000
FILE_STORAGE_IMPORT_MAX_SIZE=
FILE_STORAGE_WORKSPACE_IMPORT_MAX_SIZE=

# OIDC via Authentik
OIDC_CLIENT_ID=4DxGO5EppflGryl8NUUMRC7VkCB9pjdIQwb2llDj
OIDC_AUTH_URI=https://auth.fabricant.ucsd.edu/application/o/authorize/
OIDC_TOKEN_URI=https://auth.fabricant.ucsd.edu/application/o/token/
OIDC_USERINFO_URI=https://auth.fabricant.ucsd.edu/application/o/userinfo/
OIDC_LOGOUT_URI=https://auth.fabricant.ucsd.edu/application/o/outline/end-session/
OIDC_USERNAME_CLAIM=preferred_username
OIDC_DISPLAY_NAME=Authentik
OIDC_SCOPES=openid profile email

# SMTP via UCSD relay
SMTP_HOST=smtp.ucsd.edu
SMTP_PORT=25
SMTP_SECURE=false
SMTP_FROM_EMAIL=e4e@ucsd.edu

# Rate limiting
RATE_LIMITER_ENABLED=true
RATE_LIMITER_REQUESTS=1000
RATE_LIMITER_DURATION_WINDOW=60

ENABLE_UPDATES=true
DEBUG=http
LOG_LEVEL=info
